# ── LLM (DeepSeek via OpenAI-compatible API) ──
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Language ──
LANG=zh

# ── UiPath ──
UIPATH_AUTH_URL=https://cloud.uipath.com/identity
UIPATH_ORCHESTRATOR_URL=
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_AUTH_SCOPE=OR.Machine
UIPATH_FOLDER_ID=
UIPATH_DATASERVICE_URL=
UIPATH_REQUIREMENT_ENTITY=
UIPATH_POLL_INTERVAL=5
